  {
    "_comment": "--- Replace rules ---",
    "type": "replace_re",
    "enabled": true,
    "description": "dirs -> directories",
    "pattern": "\\bdirs\\b",
    "replacement": "directories"
  },
  {
    "type": "spell_out",
    "enabled": true,
    "description": "NVRAM -> NV RAM",
    "word": "nvram",
    "spoken": "NV RAM"
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "pflash -> pee flash",
    "pattern": "(?i)\\bpflash[0-9]*\\b",
    "replacement": "pee flash"
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "NVMe/NVME/nvme -> N V M E",
    "pattern": "(?i)\\bnvme\\b",
    "replacement": "N V M E"
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "nginx (any case) -> engine-x",
    "pattern": "(?i)\\bnginx\\b",
    "replacement": "engine-x"
  },
  {
    "type": "replace",
    "enabled": true,
    "description": "rsync -> r-sync",
    "find": "rsync",
    "replacement": "r-sync"
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "circleci -> circle C I",
    "pattern": "(?i)circleci",
    "replacement": "circle C I"
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "Strip markdown headers (# ## ###)",
    "pattern": "^#{1,6}\\s+",
    "replacement": ""
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "Numbered list markers -> pause",
    "pattern": "^\\d+\\.\\s+",
    "replacement": ""
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "gcloud",
    "pattern": "(?i)\\bgcloud\\b",
    "replacement": "Gee Cloud"
  },
  {
    "type": "spell_out",
    "enabled": true,
