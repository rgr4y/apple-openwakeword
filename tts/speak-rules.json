[
  {
    "type": "replace_re",
    "enabled": true,
    "description": "Inline code (backtick wrapped) — strip backticks, keep content",
    "pattern": "`([^`]+)`",
    "replacement": " \\1 "
  },
  {
    "type": "replace",
    "enabled": true,
    "description": "Bare backtick — strip completely",
    "find": "`",
    "replacement": ""
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "Strip all quote characters (single, double, smart)",
    "pattern": "[\"'\\u201c\\u201d\\u2018\\u2019]",
    "replacement": ""
  },
  {
    "_comment": "--- Strip rules ---",
    "type": "strip_re",
    "enabled": true,
    "description": "UUIDs and GUIDs",
    "pattern": "\\b[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\b"
  },
  {
    "type": "strip_re",
    "enabled": true,
    "description": "Hex strings (6+ hex chars, looks like a hash/id)",
    "pattern": "\\b[0-9a-f]{8,}\\b"
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "NVMe device paths (/dev/nvme0n1p2 etc) -> N V M E, 0 N, blah blah",
    "pattern": "/dev/nvme([0-9]+)(n[0-9]*)?(?:p[0-9]+)?",
    "replacement": "N V M E, \\1 N, blah blah"
  },
  {
    "type": "munge_path",
    "enabled": true,
    "description": "File paths — spoken as words with 'dot' for extensions",
    "pattern": "(?:~|\\/[\\w.\\-]+){2,}[\\w./\\-]*"
  },
  {
    "type": "strip_re",
    "enabled": true,
    "description": "URLs",
    "pattern": "https?://\\S+"
  },
  {
    "type": "strip_re",
    "enabled": true,
    "description": "Markdown code blocks",
    "pattern": "```[\\s\\S]*?```"
  },
  {
    "type": "replace_re",
    "enabled": true,
    "description": "Markdown bold/italic markers — keep content",
    "pattern": "[*_]{1,3}(.*?)[*_]{1,3}",
    "replacement": "\\1"
  },
  {
    "_comment": "--- Spell-out rules ---",
    "type": "spell_out",
    "enabled": true,
    "description": "npm -> N P M",
    "word": "npm",
    "spoken": "N P M"
  },
  {
    "type": "spell_out",
    "enabled": true,
    "description": "api -> A P I",
    "word": "api",
    "spoken": "A P I"
  },
  {
    "type": "spell_out",
    "enabled": true,
